# ───────────────────────────────────────────────
#  StockRadar — 환경 변수 샘플
# ───────────────────────────────────────────────
#  이 파일은 키 이름만 담은 템플릿입니다.
#  실제 값은 server/.env (gitignored) 또는 배포 플랫폼의 Secret Manager 에 보관하세요.

# ─── 외부 API 키 ───────────────────────────
FMP_API_KEY=             # Financial Modeling Prep API 키 — 재무 지표·회사 프로필
GEMINI_API_KEY=          # Google Gemini API 키 — AI 분석·챗봇·섹터 브리핑·가이드 초안

# ─── 서버 기본 ────────────────────────────
PORT=3000                # 서버 포트 (기본 3000)

# ─── 인증 ─────────────────────────────────
SESSION_SECRET=          # 세션 서명 키 — 반드시 32자+ 랜덤 문자열. 프로덕션에서 미설정 시 서버 fatal exit
ADMIN_SEED_EMAIL=        # 서버 최초 실행 시 자동 생성될 관리자 계정 이메일
ADMIN_SEED_PASSWORD=     # 초기 관리자 비밀번호 (첫 로그인 후 즉시 변경 필수)

# ─── 이메일 (Resend) ───────────────────────
RESEND_API_KEY=          # Resend API 키 — 이메일 인증 코드·비번 재설정 메일
EMAIL_FROM=              # 발신자 주소. 무료 테스트는 onboarding@resend.dev, 실서비스는 verify 된 도메인 사용

# ─── 소셜 로그인 (선택) ────────────────────
GOOGLE_CLIENT_ID=        # Google OAuth 2.0 클라이언트 ID
GOOGLE_CLIENT_SECRET=    # Google OAuth 2.0 클라이언트 시크릿
OAUTH_CALLBACK_BASE=     # OAuth 콜백 베이스 URL (예: https://yourdomain.com). 미설정 시 요청 host 사용

# ─── 결제/운영 (향후 · 선택) ───────────────
# KAKAO_CLIENT_ID=       # 카카오 REST API 키 — 현재 미구현, 준비 후 주석 해제
# KAKAO_CLIENT_SECRET=   # 카카오 보안 시크릿 (Security 탭 발급분)
# NAVER_CLIENT_ID=       # 네이버 애플리케이션 Client ID
# NAVER_CLIENT_SECRET=   # 네이버 애플리케이션 Client Secret

# ─── 배포 · 운영 (Railway 등, 선택) ────────
NODE_ENV=                # production 으로 두면 secure 쿠키 + same-origin 강제. 로컬 개발은 비워두거나 development
DATA_DIR=                # SQLite + sessions.db 저장 경로. Railway 볼륨은 /data 로 설정
DB_PATH=                 # DB 파일 경로 오버라이드 (선택 — 기본은 DATA_DIR/data.db)

# ─── 비용 관리 대시보드 (선택) ─────────────
USD_KRW_RATE=            # 수동 환율 고정값 (비워두면 Yahoo KRW=X 에서 1시간 캐시로 조회)
RAILWAY_MONTHLY_USD=     # Railway 호스팅 월 고정비 (어드민 비용 카드 표시용)
FMP_MONTHLY_USD=         # FMP 월 구독료 (무료 플랜이면 0)
RESEND_MONTHLY_USD=      # Resend 월 요금 (무료 3,000통이면 0)
GEMINI_FREE_CREDIT_USD=  # Gemini 무료 크레딧 차감용 (선택)
